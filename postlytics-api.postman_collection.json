        "_postman_id": "postlytics-api",
        "name": "Postlytics API",
        "description": "API collection for Postlytics - Social media analytics platform",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "variable": [
        {
            "key": "base_url",
            "value": "https://postlytics.onrender.com",
            "type": "string"
        },
        {
            "key": "auth_token",
            "value": "",
            "type": "string",
            "description": "JWT token from login response Authorization header"
        }
    ],
    "item": [
        {
            "name": "Health Check",
            "item": [
                {
                    "name": "Health Check",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{base_url}}/up",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "up"
                            ]
                        },
                        "description": "Check if the API is running. Returns green background HTML if healthy."
                    },
                    "response": []
                }
            ]
        },
        {
            "name": "Authentication",
            "item": [
                {
                    "name": "Sign Up",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "// Save auth token from response header",
                                    "const authHeader = pm.response.headers.get('Authorization');",
                                    "if (authHeader) {",
                                    "    pm.collectionVariables.set('auth_token', authHeader);",
                                    "    pm.test('Auth token saved', function() {",
                                    "        pm.expect(authHeader).to.include('Bearer');",
                                    "    });",
                                    "}",
                                    "",
                                    "pm.test('Status code is 200', function() {",
                                    "    pm.response.to.have.status(200);",
                                    "});",
                                    "",
                                    "pm.test('Response contains user', function() {",
                                    "    const jsonData = pm.response.json();",
                                    "    pm.expect(jsonData).to.have.property('user');",
                                    "    pm.expect(jsonData).to.have.property('message');",
                                    "});"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"user\": {\n        \"email\": \"testuser@example.com\",\n        \"password\": \"password123\",\n        \"password_confirmation\": \"password123\"\n    }\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/users",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "users"
                            ]
                        },
                        "description": "Register a new user. Saves JWT token to collection variables."
                    },
                    "response": []
                },
                {
                    "name": "Login",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "// Save auth token from response header",
                                    "const authHeader = pm.response.headers.get('Authorization');",
                                    "if (authHeader) {",
                                    "    pm.collectionVariables.set('auth_token', authHeader);",
                                    "    pm.test('Auth token saved', function() {",
                                    "        pm.expect(authHeader).to.include('Bearer');",
                                    "    });",
                                    "}",
                                    "",
                                    "pm.test('Status code is 200', function() {",
                                    "    pm.response.to.have.status(200);",
                                    "});",
                                    "",
                                    "pm.test('Response contains user', function() {",
                                    "    const jsonData = pm.response.json();",
                                    "    pm.expect(jsonData).to.have.property('user');",
                                    "    pm.expect(jsonData.message).to.eql('Logged in successfully');",
                                    "});"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"user\": {\n        \"email\": \"testuser@example.com\",\n        \"password\": \"password123\"\n    }\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/users/sign_in",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "users",
                                "sign_in"
                            ]
                        },
                        "description": "Login and get JWT token. Token is automatically saved to collection variables."
                    },
                    "response": []
                },
                {
                    "name": "Logout",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test('Status code is 204 No Content', function() {",
                                    "    pm.response.to.have.status(204);",
                                    "});",
                                    "",
                                    "// Clear the token",
                                    "pm.collectionVariables.set('auth_token', '');"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "DELETE",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "{{auth_token}}"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/users/sign_out",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "users",
                                "sign_out"
                            ]
                        },
                        "description": "Logout and invalidate token."
                    },
                    "response": []
                }
            ]
        },
        {
            "name": "Posts",
            "item": [
                {
                    "name": "Get All Posts",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test('Status code is 200', function() {",
                                    "    pm.response.to.have.status(200);",
                                    "});",
                                    "",
                                    "pm.test('Response is an array', function() {",
                                    "    const jsonData = pm.response.json();",
                                    "    pm.expect(jsonData).to.be.an('array');",
                                    "});",
                                    "",
                                    "pm.test('Posts have expected structure', function() {",
                                    "    const jsonData = pm.response.json();",
                                    "    if (jsonData.length > 0) {",
                                    "        const post = jsonData[0];",
                                    "        pm.expect(post).to.have.property('id');",
                                    "        pm.expect(post).to.have.property('content');",
                                    "        pm.expect(post).to.have.property('user');",
                                    "        pm.expect(post).to.have.property('likes_count');",
                                    "        pm.expect(post).to.have.property('hashtags');",
                                    "        pm.expect(post).to.have.property('comments');",
                                    "        // Save first post ID for other tests",
                                    "        pm.collectionVariables.set('post_id', post.id);",
                                    "    }",
                                    "});"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "{{auth_token}}",
                                "description": "Optional - needed for liked_by_current_user field"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/posts?page=1&per_page=15",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "posts"
                            ],
                            "query": [
                                {
                                    "key": "page",
                                    "value": "1"
                                },
                                {
                                    "key": "per_page",
                                    "value": "15"
                                }
                            ]
                        },
                        "description": "Get paginated list of posts with comments, likes, and hashtags."
                    },
                    "response": []
